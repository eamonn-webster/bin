xcver="-$1"
if [ "$xcver" == "--" ]
then
  xcver=""
fi


if [ "$xcver" != "-" ]
then
  xcode="/Applications/Xcode${xcver}.app/Contents/Developer"

  if [[ -d $xcode ]] ; then
    sudo xcode-select -s $xcode
  else
    echo "xcode $xcode not found"
  fi
fi

xcode-select -p
