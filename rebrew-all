class FirstUnlink < StandardError
end

open("|brew list -1").each_line do |formula|
  puts formula
  begin
    open("|brew reinstall #{formula}").each_line do |line|
      puts line
      if line ~= /To install this version, first `(brew unlink .+)'/
        raise FirstUnlink
      end
    end
  rescue FirstUnlink
    open("|brew unlink #{formula}").each_line do |line|
      puts line
    end
    retry
  end
end
