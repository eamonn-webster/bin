import os
import sys
import requests
import logging
import threading
from datetime import datetime
from mutagen import File
from mutagen.id3 import ID3, USLT
from mutagen.mp4 import MP4
from concurrent.futures import ThreadPoolExecutor, as_completed
from tqdm import tqdm

SUPPORTED = (".mp3", ".flac", ".m4a", ".ogg", ".wav")
MAX_WORKERS = 4
LOG_FILE = f"embed_lyrics_{datetime.now().strftime('%Y-%m-%d-%H-%M-%S')}.log"

thread_local = threading.local()

# ---------------- Logging ----------------

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s"
)

logging.info("==== Lyrics embedding started ====")

# ---------------- Functions ----------------

def get_session():
    if not hasattr(thread_local, "session"):
        session = requests.Session()
        adapter = requests.adapters.HTTPAdapter(
            pool_connections=10,
            pool_maxsize=10,
            max_retries=3,
        )
        session.mount("http://", adapter)
        session.mount("https://", adapter)
        thread_local.session = session
    return thread_local.session

def get_tags(path):
    audio = File(path, easy=True)
    if not audio:
        return None, None
    artist = audio.get("artist", [None])[0]
    title = audio.get("title", [None])[0]
    return artist, title

def has_lyrics(path):
    try:
        audio = File(path)
        if not audio:
            return False

        if path.lower().endswith(".mp3"):
            tags = ID3(path)
            for key in tags.keys():
                if key.startswith("USLT"):
                    return True
            return False
        elif path.lower().endswith(".m4a"):
            audio = MP4(path)
            return "©lyr" in audio
        else:
            return "lyrics" in audio or "LYRICS" in audio
    except Exception as e:
        logging.error(f"Failed reading lyrics tag: {path} - {e}")
        return False

def fetch_lyrics(artist, title):
    url = "https://lrclib.net/api/get"
    params = {
        "artist_name": artist,
        "track_name": title
    }

    # try:
    session = get_session()
    r = session.get(url, params=params, timeout=10)
    if r.status_code != 200:
        return None
    data = r.json()
    return data.get("plainLyrics") or data.get("syncedLyrics")
    # except Exception as e:
    #     logging.error(f"Fetch error for {artist} - {title}: {e}")
    #     return None

def embed_mp3(path, lyrics):
    audio = ID3(path)
    audio.delall("USLT")
    audio.add(USLT(encoding=3, lang="eng", desc="Lyrics", text=lyrics))
    audio.save()

def embed_mp4(path, lyrics):
    audio = MP4(path)
    audio["©lyr"] = lyrics
    audio.save()

def embed_generic(path, lyrics):
    audio = File(path)
    audio["lyrics"] = lyrics
    audio.save()

def embed_lyrics(path, lyrics):
    if path.lower().endswith(".mp3"):
        embed_mp3(path, lyrics)
    elif path.lower().endswith(".m4a"):
        embed_mp4(path, lyrics)
    else:
        embed_generic(path, lyrics)

def process_file(path):
    try:
        artist, title = get_tags(path)
        if not artist or not title:
            logging.warning(f"NO-TAGS: {path}")
            return "no_tags"

        # if title in ["Black Mountain Side", "White Summer", "White Summer/Black Mountain Side"]:
        #     embed_lyrics(path, "Instrumental")

        if has_lyrics(path):
            logging.info(f"HAVE-LYRICS: {artist} - {title}")
            return "skipped"

        if title in ["Guitar Solo", "Organ Solo"]:
            lyrics = "Instrumental"
        elif title in ["Moby Dick", "Drum Solo"]:
            lyrics = "Drum Solo"
        else:
            lyrics = fetch_lyrics(artist, title)

        instrumental_artists = []
        if not lyrics:
            if artist in instrumental_artists:
                lyrics = "Instrumental"
        if not lyrics:
            logging.info(f"NO-LYRICS: {artist} - {title}")
            return "no_lyrics"

        embed_lyrics(path, lyrics)
        logging.info(f"EMBEDDED: {artist} - {title}")
        return "embedded"

    except Exception as e:
        logging.error(f"FAILED: {path} - {e}")
        return "failed"

# ---------------- Main ----------------

def main():
    if len(sys.argv) < 2:
        print("Usage: embed_lyrics_mt.py <music_folder>")
        sys.exit(1)

    music_dir = sys.argv[1]
    if not os.path.isdir(music_dir):
        print("Invalid folder")
        sys.exit(1)

    files = []
    for root, _, filenames in os.walk(music_dir):
        for f in filenames:
            if f.lower().endswith(SUPPORTED):
                files.append(os.path.join(root, f))

    print(f"Found {len(files)} audio files\n")

    stats = {
        "embedded": 0,
        "skipped": 0,
        "no_tags": 0,
        "no_lyrics": 0,
        "failed": 0
    }

    with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
        futures = [executor.submit(process_file, f) for f in files]

        for future in tqdm(as_completed(futures), total=len(futures), desc="Processing"):
            result = future.result()
            stats[result] += 1

    print("\nDone!\n")
    for k, v in stats.items():
        print(f"{k:10}: {v}")

    logging.info("==== Lyrics embedding finished ====")

if __name__ == "__main__":
    main()
