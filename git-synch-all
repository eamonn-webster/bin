require 'open3'

bin_dir = File.expand_path('../', __FILE__)
# puts bin_dir

dir_to_do = nil
do_tags = true
do_apps = true

ARGV.each do |arg|
  if arg == '--no-tags'
    do_tags = false
    nil
  elsif arg == '--no-apps'
    do_apps = false
    nil
  else
    dir_to_do ||= arg
  end
end

def app_list
  apps = []
  all_apps = %x{heroku apps --all}
  all_apps.each_line do |app|
    app.chomp!
    app = app.split(' ')[0]
    if app =~ /^qs-/ || app =~ /^eweb-/
      #puts "[#{app}]"
      apps << app
    end
  end
  apps
end

Dir["#{ENV['HOME']}/projects/qstream/*"].each do |dir|
  next if !Dir.exist?(dir)
  next if dir_to_do && File.basename(dir) != dir_to_do
  Dir.chdir(dir) do |dir|
    next unless Dir.exist?('.git')
    remote = %x{git remote -v | grep -e 'origin.\\+fetch'}.chomp
    if remote =~ %r{git@github.com:qstream/(.+)(?:\.git) } ||
       remote =~ %r{https://github.com/qstream/(.+)(?:\.git) }
      remote = Regexp.last_match(0)
      repo = $1
      current = `git rev-parse --abbrev-ref HEAD`.chomp
      puts "\033[0;34m#{dir}\033[0m \033[0;35m#{current}\033[0m \033[0;36m#{remote}\033[0m"

      Open3.popen2e("git", "remote", "update", "-p") {|i,oe,t|
        oe.each {|line|
          line.chomp!
          if /Fetching repository, done./ =~ line
          elsif /Already up-to-date./ =~ line
          elsif /Fetching (.+)/ =~ line
            print "\033[2K\r#{line}"
          else
            puts line
          end
        }
      }
      print "\033[2K\r"

      # for each remote that matches an app
      if (repo == 'qs-core' || repo == 'spaced-ed') && do_tags
        app_list.each do |app|
          #tags = `#{bin_dir}/tag-releases.rb #{app}`.chomp
          tags = `tag-releases #{app}`.chomp
          puts tags unless tags.empty?
        end
        do_tags = false
      end

      case repo
        when 'qs-core', 'spaced-ed'
          branches = %w{master maintenance sprint}
        when 'qs-user-admin', 'qs-angular-core'
          branches = %w{master sprint maintenance}
        when 'QstreamIOS'
          branches = %w{master sprint}
        else
          branches = %w{master}
      end

      branches.each do |br|
        next if br === current
        matching = `git branch --list --remote origin/#{br}`
        unless matching.empty?
          matching.each_line do |line|
            line.chomp!
            if line =~ %r(origin/(.+))
              if $1 != current
                system("git update-ref refs/heads/#{$1} remotes/origin/#{$1}")
              end
            end
          end
        end
      end

      Open3.popen2e("git", "pull", "-p") {|i,oe,t|
        oe.each {|line|
          line.chomp!
          if /Fetching repository, done./ =~ line
          elsif /Already up-to-date./ =~ line
          elsif /Fetching (.+)/ =~ line
            #print "\033[2K\r#{line}"
          else
            puts line
          end
        }
      }
      # print "\033[2K\r"
    else
      puts "ignoring [#{dir}] [#{remote}]"
    end
  end
end

if do_apps
  puts 'app configs'
  Dir.chdir("#{ENV['HOME']}/projects/qstream/apps") do |dir|
    %x{./app_configs.rb}
    %x{git commit -a -m 'fetched'}
  end
end
