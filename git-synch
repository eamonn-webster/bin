system("git remote update")

branches = %w{master trove-master edge}

current = `git rev-parse --abbrev-ref HEAD`.chomp

puts "current [#{current}]"

branches.each do |br|
  next if br == current
  system("git update-ref refs/heads/#{br} remotes/origin/#{br}")
end

system("git pull")
